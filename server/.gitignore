# ===========================
# Server .gitignore
# ===========================

# Dependencies
node_modules/

# Environment Variables - NEVER commit!
.env
.env.*
!.env.example

# SQLite Database (contains user data)
*.db
*.db-journal
*.sqlite

# Uploaded Files (user private files)
uploads/

# Prisma generated client
node_modules/.prisma/

# Logs
*.log
